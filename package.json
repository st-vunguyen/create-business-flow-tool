{
  "name": "create-business-flow-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "description": "CLI tool to normalize multi-format specs, generate business-flow documents, and convert them to Mermaid diagrams.",
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "bin": {
    "business-flow-tool": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "doctor": "tsx src/cli.ts doctor",
    "generate:icons": "node tools/generate-semantic-icon-library.mjs",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prepare": "pnpm run build",
    "sync-adapters": "node tools/sync-adapters.mjs",
    "tool": "tsx src/cli.ts",
    "tool:dist": "node dist/cli.js",
    "test": "node --test --import tsx tests/**/*.test.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "mammoth": "^1.9.1",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
